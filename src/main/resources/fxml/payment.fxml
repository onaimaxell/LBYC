<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.dasalla.pos.controller.PaymentController"
      styleClass="screen-root" spacing="0"
      prefWidth="380" prefHeight="550">

    <HBox styleClass="top-bar" alignment="CENTER">
        <Label text="Process Payment" styleClass="top-bar-title"/>
    </HBox>

    <ScrollPane fitToWidth="true" styleClass="main-scroll" VBox.vgrow="ALWAYS">
        <VBox spacing="14" styleClass="content-pad">

            <VBox styleClass="card" spacing="6" alignment="CENTER">
                <Label fx:id="orderNumLabel" text="Order #00000" styleClass="order-num-label"/>
                <Label fx:id="amountLabel" text="₱0.00" styleClass="stat-value-green"/>
            </VBox>

            <!-- Payment Method -->
            <VBox styleClass="card" spacing="10">
                <Label text="Payment Method" styleClass="field-label"/>
                <HBox spacing="10">
                    <ToggleButton fx:id="btnCash" text="💵 Cash" styleClass="service-tab" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <ToggleButton fx:id="btnGCash" text="📱 GCash" styleClass="service-tab" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                </HBox>
            </VBox>

            <!-- Cash Panel -->
            <VBox fx:id="cashPanel" styleClass="card" spacing="10">
                <Label text="Cash Payment" styleClass="field-label"/>
                <VBox spacing="6">
                    <Label text="Amount Received (₱)" styleClass="field-label"/>
                    <TextField fx:id="cashReceivedField" promptText="0.00" styleClass="input-field"/>
                </VBox>
                <Label fx:id="changeLabel" text="Change: ₱0.00" styleClass="change-label"/>
            </VBox>

            <!-- GCash Panel -->
            <VBox fx:id="gcashPanel" styleClass="card" spacing="10" alignment="CENTER">
                <Label text="Scan GCash QR Code" styleClass="field-label"/>
                <ImageView fx:id="gcashQRView" fitWidth="180" fitHeight="180" preserveRatio="true"/>
                <Label text="Scan the QR code using GCash app" styleClass="hint-label"/>
                <VBox spacing="6">
                    <Label text="GCash Reference Number (optional)" styleClass="field-label"/>
                    <TextField fx:id="gcashRefField" promptText="Enter reference number" styleClass="input-field"/>
                </VBox>
            </VBox>

        </VBox>
    </ScrollPane>

    <HBox styleClass="bottom-bar" spacing="10">
        <Button fx:id="btnCancel" text="Cancel" styleClass="btn-outline" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
        <Button fx:id="btnConfirmPay" text="✓ Confirm Payment" styleClass="btn-pay" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
    </HBox>
</VBox>
