<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.dasalla.pos.controller.LoginController"
      styleClass="screen-root"
      alignment="CENTER" spacing="0"
      prefWidth="420" prefHeight="700">

    <VBox alignment="CENTER" spacing="8" styleClass="login-header">
        <Label text="👕" style="-fx-font-size: 52px;"/>
        <Label text="Dasalla Laundry" styleClass="app-title"/>
        <Label text="Point of Sale System" styleClass="app-subtitle"/>
    </VBox>

    <VBox styleClass="login-card" spacing="16">
        <Label text="Sign In" styleClass="section-title"/>

        <VBox spacing="6">
            <Label text="Username" styleClass="field-label"/>
            <TextField fx:id="usernameField" promptText="Enter username" styleClass="input-field"/>
        </VBox>

        <VBox spacing="6">
            <Label text="Password" styleClass="field-label"/>
            <PasswordField fx:id="passwordField" promptText="Enter password" styleClass="input-field"/>
        </VBox>

        <Label fx:id="errorLabel" styleClass="error-label" text="" wrapText="true"/>

        <Button fx:id="loginButton" text="Login" styleClass="btn-primary" maxWidth="Infinity"/>

        <Label text="Default accounts: admin/admin123 | cashier/cashier123 | staff/staff123"
               styleClass="hint-label" wrapText="true" textAlignment="CENTER"/>
    </VBox>

    <VBox.margin>
        <Insets top="40"/>
    </VBox.margin>
</VBox>
