<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.dasalla.pos.controller.OrderSummaryController"
      styleClass="screen-root" spacing="0"
      prefWidth="420" prefHeight="700">

    <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="8">
        <Button fx:id="btnBack" text="&lt; Back" styleClass="btn-back"/>
        <Label text="Order Summary" styleClass="top-bar-title" HBox.hgrow="ALWAYS"/>
    </HBox>

    <ScrollPane fitToWidth="true" styleClass="main-scroll" VBox.vgrow="ALWAYS">
        <VBox spacing="14" styleClass="content-pad">

            <!-- Order Header Card -->
            <VBox styleClass="card" spacing="10" alignment="CENTER">
                <HBox alignment="CENTER" spacing="12">
                    <ImageView fx:id="receiptQRView" fitWidth="80" fitHeight="80" preserveRatio="true"/>
                    <VBox alignment="CENTER_LEFT" spacing="4">
                        <Label fx:id="orderNumberLabel" text="#00000" styleClass="order-num-label"/>
                        <Label text="Dasalla Laundry Shop" styleClass="shop-label"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- Items -->
            <VBox styleClass="card" spacing="8">
                <Label text="Items" styleClass="field-label"/>
                <VBox fx:id="itemsContainer" spacing="6"/>
                <Separator/>
                <HBox alignment="CENTER_RIGHT" spacing="8">
                    <Label text="Order Total" styleClass="field-label"/>
                    <Label fx:id="totalLabel" text="₱0.00" styleClass="total-label"/>
                </HBox>
            </VBox>

            <!-- Status Update -->
            <VBox styleClass="card" spacing="8">
                <Label text="Order Status" styleClass="field-label"/>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <ComboBox fx:id="statusCombo" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <Button fx:id="btnUpdateStatus" text="Update" styleClass="btn-secondary"/>
                </HBox>
            </VBox>

        </VBox>
    </ScrollPane>

    <!-- Pay Button -->
    <VBox styleClass="bottom-bar" spacing="8">
        <Button fx:id="btnPay" text="Pay" styleClass="btn-pay" maxWidth="Infinity"/>
        <HBox spacing="20" alignment="CENTER">
            <VBox alignment="CENTER" spacing="4">
                <ImageView fx:id="lookupQRView" fitWidth="50" fitHeight="50" preserveRatio="true"/>
                <Label text="Receipt QR" styleClass="qr-label"/>
            </VBox>
        </HBox>
    </VBox>
</VBox>
